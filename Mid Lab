#include <iostream>
#include <cstring>
using namespace std;

char keywords[10][10] = {"int", "main", "float", "char", "if", "else", "while", "for", "return", "void"};

bool isKeyword(char str[]) {

    for (int i = 0; i < 10; i++)

        if (strcmp(keywords[i], str) == 0) return true;

    return false;

}

bool isOperator(char ch) {

    return (ch=='+' || ch=='-' || ch=='*' || ch=='/' || ch=='=' || ch=='<' || ch=='>');

}

bool isDelimiter(char ch) {

    return (ch==' ' || ch==',' || ch==';' || ch=='(' || ch==')' || ch=='{' || ch=='}');

}

int main() {

    char code[] = "int main() { int a = 10; return 0; }";

    char token[20];

    int j = 0;

    cout << "Source: " << code << endl << endl;

    cout << "TOKEN\t\tTYPE" << endl;

    cout << "------------------------" << endl;

    for (int i = 0; i <= strlen(code); i++) {

        char ch = code[i];

        if (isDelimiter(ch) || isOperator(ch) || ch == '\0') {

            if (j > 0) {

                token[j] = '\0';

                if (isKeyword(token))

                    cout << token << "\t\tKEYWORD" << endl;

                else if (token[0] >= '0' && token[0] <= '9')

                    cout << token << "\t\tNUMBER" << endl;

                else

                    cout << token << "\t\tIDENTIFIER" << endl;

                j = 0;

            }

            if (isOperator(ch))

                cout << ch << "\t\tOPERATOR" << endl;

            else if (ch != ' ' && ch != '\0')

                cout << ch << "\t\tDELIMITER" << endl;

        }

        else {

            token[j++] = ch;

        }

    }

    return 0;

}
