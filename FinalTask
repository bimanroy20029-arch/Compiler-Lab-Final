#include <iostream>
#include <string>
using namespace std;
 
bool isAccepted(string input) {
    for (int i = 0; i < input.length(); i++) {
        if (input[i] != 'a' && input[i] != 'b') {
            return false;
        }
    }
    return true;
}
 
int main() {
    string input;
 
    cout << "Enter a string: ";
    cin >> input;
 
    if (isAccepted(input)) {
        cout << "Accepted" << endl;
    } else {
        cout << "Rejected" << endl;
    }
 
    return 0;
}
